# grotti.conf — copy this to `grotti.conf` next to the grotti binary.
#
# These values override the built-in defaults; command-line flags override these.
# Keys match the CLI flags. Lines starting with '#' or ';' are comments.

# Stratum pool endpoint. Accepts "host:port" or "stratum+tcp://host:port".
pool = stratum+tcp://pool.drivechain.info:3334

# Stratum username: <thunder-addr>.<rig>
user = YOUR_THUNDER_ADDRESS.rig0

# Backend: auto | cpu | cuda | vulkan | metal | comma-combo (e.g. cpu,cuda).
# `auto` (the default) picks the fastest available (cuda > metal > vulkan > cpu), governed.
backend = auto

# CPU worker threads (only used when the backend includes cpu)
threads = 4

# Cap: 0 = uncapped, 1-100 = percent of estimated max (e.g. 50), >100 = raw H/s
cap = 50

# Color: auto | always | never
color = auto
